{
  "name": "ndjson-local-log-triage-mcp",
  "version": "0.3.0",
  "description": "MCP server for streaming NDJSON log triage — query patterns, detect anomalies, summarize timelines without loading gigabyte files into context.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ndjson-local-log-triage-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "server.json"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc && chmod +x dist/index.js",
    "prepack": "chmod +x dist/index.js",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "ndjson",
    "logs",
    "log-triage",
    "anomaly-detection",
    "developer-tools",
    "ai-tools"
  ],
  "author": "vola-trebla",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "**/*.{ts,mjs,json,md}": [
      "prettier --write"
    ],
    "src/**/*.ts": [
      "eslint --fix"
    ]
  },
  "mcpName": "io.github.vola-trebla/ndjson-local-log-triage-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/vola-trebla/ndjson-local-log-triage-mcp.git"
  }
}
